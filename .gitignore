# BEAST3D encoding raw data — huge (pointcloud_4d.npz ~600MB over GitHub's
# 100MB limit; videos_cut/ ~280MB of full-length source). The committed web/
# assets (generated by make_web_encoding.py + the cut grid clip) are what the
# page actually loads.
projects/beast3d/assets/encoding/**/*.npz
projects/beast3d/assets/encoding/chickadee/videos_cut/

# BEAST3D: video variants the page never shows (only *_fuse_* teasers and
# *half_orbit_render* orbits are used). Kept on disk, excluded from the repo.
projects/beast3d/assets/**/orig/
projects/beast3d/assets/**/*_6view_render_*.mp4
projects/beast3d/assets/**/*_4view_render_*.mp4
projects/beast3d/assets/**/*half_orbit_mask*.mp4

# BEAST3D encoding: local segment backups + the unused full-timeline raster
# (the page only loads meta.json, raster_seg_u8.bin, pc_xyz_i16.bin, input_6view_seg.mp4).
projects/beast3d/assets/encoding/chickadee/web_seg_10s/
projects/beast3d/assets/encoding/chickadee/web_seg60_active/
projects/beast3d/assets/encoding/chickadee/web/raster_full_u8.bin

# BEAST3D: raw half-orbit 4D point-cloud npz (source for the Explore panel).
# make_web_pc4d.py converts these to the small pc4d.bin files that ship.
projects/beast3d/assets/**/*half_orbit_pc*.npz